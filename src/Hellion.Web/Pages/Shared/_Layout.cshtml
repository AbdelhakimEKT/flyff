@using Microsoft.AspNetCore.Identity
@using Hellion.Web.Data
@inject SignInManager<AdminUser> SignInManager
@inject UserManager<AdminUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — Hellion Admin</title>
    <style>
        :root { color-scheme: dark light; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; margin: 0; background: #111; color: #eee; }
        header { background: #1f1f1f; border-bottom: 1px solid #333; padding: 12px 24px; display: flex; align-items: center; gap: 24px; }
        header h1 { font-size: 16px; margin: 0; }
        header nav a { color: #ccc; text-decoration: none; margin-right: 16px; }
        header nav a:hover { color: #fff; }
        header .spacer { flex: 1; }
        main { max-width: 1100px; margin: 24px auto; padding: 0 24px; }
        h2 { border-bottom: 1px solid #333; padding-bottom: 8px; }
        table { width: 100%; border-collapse: collapse; margin: 16px 0; }
        th, td { text-align: left; padding: 8px 12px; border-bottom: 1px solid #2a2a2a; }
        th { background: #1a1a1a; }
        form button, .btn { background: #2563eb; color: white; border: 0; padding: 6px 14px; border-radius: 4px; cursor: pointer; }
        form button.danger { background: #b91c1c; }
        .card { background: #1a1a1a; border: 1px solid #2a2a2a; border-radius: 6px; padding: 16px; }
        .grid { display: grid; gap: 16px; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); }
        .stat { font-size: 28px; font-weight: 600; }
        .muted { color: #888; font-size: 13px; }
    </style>
</head>
<body>
    <header>
        <h1>Hellion Admin</h1>
        <nav>
            <a asp-page="/Index">Home</a>
            @if (SignInManager.IsSignedIn(User))
            {
                <a asp-page="/Admin/Dashboard">Dashboard</a>
                <a asp-page="/Admin/Accounts">Accounts</a>
                <a asp-page="/Admin/Characters">Characters</a>
                <a asp-page="/Admin/Gm">GM</a>
            }
        </nav>
        <div class="spacer"></div>
        <nav>
            @if (SignInManager.IsSignedIn(User))
            {
                <span class="muted">@User.Identity?.Name</span>
                <form method="post" asp-area="Identity" asp-page="/Account/Logout" style="display:inline">
                    <button type="submit" class="btn">Sign out</button>
                </form>
            }
            else
            {
                <a asp-area="Identity" asp-page="/Account/Login">Sign in</a>
            }
        </nav>
    </header>
    <main>
        @RenderBody()
    </main>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
