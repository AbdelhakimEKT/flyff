@page
@model Hellion.Web.Pages.Admin.DashboardModel
@{
    ViewData["Title"] = "Dashboard";
}

<h2>Dashboard</h2>

<div class="grid">
    <div class="card">
        <div class="muted">Accounts</div>
        <div class="stat">@Model.AccountCount</div>
    </div>
    <div class="card">
        <div class="muted">Characters</div>
        <div class="stat">@Model.CharacterCount</div>
    </div>
    <div class="card">
        <div class="muted">Items stored</div>
        <div class="stat">@Model.ItemCount</div>
    </div>
    <div class="card">
        <div class="muted">Banned accounts</div>
        <div class="stat">@Model.BannedCount</div>
    </div>
</div>

<p class="muted" style="margin-top:24px">
    Note: live player count (online clients) is exposed by the World server runtime;
    it will be wired through ISC in a follow-up.
</p>
